@using EventSharedExpenseTracker.MvC.ViewModels.Trips
@model TripDetailsViewModel

@*ADD PARTICIPANT*@
<form asp-action="Edit"> @*so anitforgety validates otherwise 400*@
    <div class="input-group input-group-sm">
        <input type="text" 
                class="form-control border-info rounded-top-0 border-top-0 bg-secondary" placeholder="search users or dummy name" required
                name="searchString" 
                id="searchString"
                hx-get="@Url.Action("Search", "Friends", new { tripId = Model.Id })"
                hx-target="#@Model.EIdSearchParticipants"
                hx-trigger="keyup changed delay:300ms" />

        <button type="button"
                class="btn btn-sm btn-outline-info border-info rounded-top-0 border-top-0"
                hx-post="@Url.Action("AddDummy", "Trips", new { id = Model.Id })"
                hx-target="#@Model.EIdTripParticipants"
                hx-select="#@Model.EIdTripParticipants"
                hx-include="#searchString">
            Add Dummy
        </button>

        @*EDIT + DELETE*@
        <button type="button" 
                class="btn btn-sm btn-outline-secondary border-top-0 rounded-top-0"
                hx-get="@Url.Action("Edit", "Trips", new { id = Model.Id })"
                hx-target="#@Model.EIdEditTrip">
            Edit
        </button>
        <button type="button"
                class="btn btn-sm btn-outline-danger border-top-0 rounded-top-0"
                hx-post="@Url.Action("Delete", "Trips", new { id = Model.Id })"
                hx-target="body"
                hx-push-url="true"
                hx-confirm="Are you sure you want to delete this item?">
            Delete
        </button>
    </div>
</form>
